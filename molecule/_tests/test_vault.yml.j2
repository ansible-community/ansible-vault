---
port:
  tcp:8200:
    listening: true
service:
  vault.service:
    enabled: true
    running: true
user:
  vault:
    exists: true
    groups:
      - {{ vault_group | default('bin') }}
group:
  {{ vault_group | default('bin') }}:
    exists: true
process:
  vault:
    running: true
file:
  {{ vault_run_path | default('/var/run/vault') }}:
    # a vault_install_hashi_repo-based install does not use vault_run_path
    exists: {{ 'false' if (vault_install_hashi_repo | default(false) | bool) else 'true' }}
  {{ vault_log_path | default('/var/log/vault') }}:
    # vault_log_path is only created when vault_enable_log is true
    exists: {{ 'true' if (vault_enable_log | default(false) | bool) else 'false' }}
